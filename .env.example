# Solana RPC for holder analysis (Helius free tier)
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY_HERE

# Database
DB_PATH=data/quant_harvest.db

# DexScreener
DEXSCREENER_BASE_URL=https://api.dexscreener.com

# Polling
POLL_INTERVAL_SECONDS=4
ROLLING_WINDOW_SIZE=50

# Quant thresholds
HURST_THRESHOLD=0.6
MAX_GINI_COEFFICIENT=0.85
CVD_LOOKBACK_PERIODS=10

# Paper trading risk
HARD_STOP_PCT=0.15
TRAILING_STOP_PCT=0.10
TIME_STOP_MINUTES=30
MAX_OPEN_PAPER_TRADES=5

# Filters
MIN_LIQUIDITY_USD=10000
MIN_VOLUME_5M_USD=100

# Rate limits
DEXSCREENER_REQUESTS_PER_MINUTE=30
RPC_REQUESTS_PER_MINUTE=20

# Logging
LOG_LEVEL=DEBUG
LOG_FILE=logs/harvester.log

# Top holders to fetch for Gini
TOP_HOLDERS_COUNT=50
