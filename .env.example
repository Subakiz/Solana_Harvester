# ═══════════════════════════════════════════════════════════════
# SOLANA HARVESTER v4.0 — Configuration
# ═══════════════════════════════════════════════════════════════

# Solana RPC for holder analysis (Helius free tier)
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY_HERE

# Database
DB_PATH=data/quant_harvest.db

# DexScreener
DEXSCREENER_BASE_URL=https://api.dexscreener.com

# ── Polling ───────────────────────────────────────────────────
POLL_INTERVAL_SECONDS=4
ROLLING_WINDOW_SIZE=50
MAIN_LOOP_INTERVAL_SECONDS=1.0

# ── Quant Signal Gates ───────────────────────────────────────
# These are now ACTIVE entry filters (skipped if data unavailable)
HURST_THRESHOLD=0.70
MAX_GINI_COEFFICIENT=0.35
MIN_CVD_SLOPE=10.0
MAX_CVD_SLOPE=2000.0
CVD_LOOKBACK_PERIODS=10

# ── Entry Filters ─────────────────────────────────────────────
MIN_LIQUIDITY_USD=50000
MIN_VOLUME_5M_USD=500
MIN_MARKET_CAP=50000
MAX_MARKET_CAP=2000000
MIN_BUY_RATIO=0.40
MAX_BUY_RATIO=0.75
MIN_ACTIVITY_TXNS=3

# ── Exit Rules ────────────────────────────────────────────────
# Only DYNAMIC_TP, TIME_STOP, and RUG_PROTECTION remain
# Trailing stop and hard stop were REMOVED in v3.0
TIME_STOP_MINUTES=30
RUG_PROTECTION_PCT=-0.50

# ── Position Sizing ───────────────────────────────────────────
POSITION_PCT=0.05
MAX_LIQUIDITY_PCT=0.02
MIN_TRADE_SIZE_USD=1.00
INITIAL_BALANCE=58.0

# ── Risk Management ──────────────────────────────────────────
MAX_OPEN_PAPER_TRADES=10
MAX_POSITIONS_PER_TOKEN=1
DAILY_LOSS_LIMIT_PCT=0.15
CIRCUIT_BREAKER_MINUTES=60
LARGE_LOSS_THRESHOLD_PCT=-0.10
LOSS_COOLDOWN_MINUTES=5.0

# ── Cost Model ────────────────────────────────────────────────
FEE_PER_SIDE_PCT=0.003
SLIPPAGE_FACTOR=0.5
MAX_SLIPPAGE_PCT=0.25

# ── Rate Limits ───────────────────────────────────────────────
DEXSCREENER_REQUESTS_PER_MINUTE=300
RPC_REQUESTS_PER_MINUTE=20
API_RATE_LIMIT_PER_MINUTE=55

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=DEBUG
LOG_FILE=logs/harvester.log

# ── Misc ──────────────────────────────────────────────────────
TOP_HOLDERS_COUNT=50
