# ═══════════════════════════════════════════════════════════════
# SOLANA HARVESTER v5.0 — Configuration
# ═══════════════════════════════════════════════════════════════

# Solana RPC for holder analysis (Helius free tier)
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY_HERE

# Database
DB_PATH=data/quant_harvest.db

# DexScreener
DEXSCREENER_BASE_URL=https://api.dexscreener.com

# ── Polling ───────────────────────────────────────────────────
POLL_INTERVAL_SECONDS=4
ROLLING_WINDOW_SIZE=80
MAIN_LOOP_INTERVAL_SECONDS=1.0

# ── Quant Signal Gates ───────────────────────────────────────
# These are now ACTIVE entry filters (skipped if data unavailable)
HURST_THRESHOLD=0.70
# v5.0: MAX_GINI raised from 0.35 to 0.85 (only reject extreme rug risk)
MAX_GINI_COEFFICIENT=0.85
MIN_CVD_SLOPE=10.0
MAX_CVD_SLOPE=2000.0
CVD_LOOKBACK_PERIODS=10
MIN_SNAPSHOTS_HURST=15

# ── Entry Filters ─────────────────────────────────────────────
# v5.0: MIN_LIQUIDITY raised from $50K to $75K
MIN_LIQUIDITY_USD=75000
MIN_VOLUME_5M_USD=500
MIN_MARKET_CAP=50000
MAX_MARKET_CAP=2000000
# v5.0: MIN_BUY_RATIO raised from 0.40 to 0.65 (genuine momentum)
MIN_BUY_RATIO=0.65
# v5.0: MAX_BUY_RATIO raised from 0.75 to 0.95 (allow real pumps)
MAX_BUY_RATIO=0.95
# v5.0: MIN_ACTIVITY_TXNS raised from 3 to 15 (organic signal minimum)
MIN_ACTIVITY_TXNS=15

# ── Momentum Confirmation Filter (v4.1) ──────────────────────
# Lightweight momentum check between buy ratio and quant gates
MOMENTUM_CHECK_ENABLED=true
MOMENTUM_SMA_LOOKBACK=10
MOMENTUM_DELTA_LOOKBACK=5

# ── Exit Rules ────────────────────────────────────────────────
TIME_STOP_MINUTES=30
# v5.0: RUG_PROTECTION is now a catastrophic circuit breaker only (-25%)
RUG_PROTECTION_PCT=-0.25

# ── Scaled Exit System (v4.1) ────────────────────────────────
# Partial TP: sell this fraction at dynamic TP (1.0 = full sell, disables trailing)
# v5.0: changed from 0.50 to 0.60 (60/40 split is better)
PARTIAL_TP_SELL_PCT=0.60
# Trailing stop: % pullback from peak to trigger trailing exit on remainder
TRAILING_STOP_PCT=0.25
# Trailing activation: minimum gain above entry before trailing activates
TRAILING_ACTIVATION_PCT=0.05
# Max gain cap: force full exit at this gain (anti-greed)
MAX_GAIN_PCT=2.00
# Extended time stop for trailing portion
MAX_POSITION_TIME_MINUTES=180

# ── Partial Stop Loss (v4.1 — deprecated in v5.0 in favour of liquidity-scaled SL) ─
PARTIAL_STOP_LOSS_PCT=-0.08
PARTIAL_STOP_SELL_PCT=0.50

# ── Trade Cooldown (v4.1) ────────────────────────────────────
# Cooldown period after exiting a token before re-entry
TRADE_COOLDOWN_MINUTES=5.0

# ── Position Sizing ───────────────────────────────────────────
POSITION_PCT=0.05
MAX_LIQUIDITY_PCT=0.02
MIN_TRADE_SIZE_USD=1.00
INITIAL_BALANCE=58.0

# ── Risk Management ──────────────────────────────────────────
# v5.0: MAX_OPEN_PAPER_TRADES reduced from 5 to 3 (less portfolio heat)
MAX_OPEN_PAPER_TRADES=3
MAX_POSITIONS_PER_TOKEN=1
DAILY_LOSS_LIMIT_PCT=0.15
CIRCUIT_BREAKER_MINUTES=60
LARGE_LOSS_THRESHOLD_PCT=-0.10
LOSS_COOLDOWN_MINUTES=5.0

# ── Cost Model ────────────────────────────────────────────────
FEE_PER_SIDE_PCT=0.005
SLIPPAGE_FACTOR=5.0
MAX_SLIPPAGE_PCT=3.0
# Minimum slippage floor per side (realistic DEX swap cost)
BASE_SLIPPAGE_PCT=0.01
# Estimated SOL priority fee per transaction in USD
PRIORITY_FEE_USD=0.05

# ── Enhanced Discovery (v4.1) ────────────────────────────────
# Enable latest pairs endpoint for new token discovery
DISCOVERY_ENABLE_LATEST_PAIRS=true
# Enable token profiles endpoint for active developer discovery
DISCOVERY_ENABLE_PROFILES=true

# ── Tracking Gate ─────────────────────────────────────────────
# Minimum liquidity for a token to appear in the analyzable set.
# Intentionally lower than MIN_LIQUIDITY_USD so the paper engine's own
# entry filter decides what qualifies — tracking is free, exclusion is not.
TRACKING_MIN_LIQUIDITY_USD=5000

# ── Rate Limits ───────────────────────────────────────────────
DEXSCREENER_REQUESTS_PER_MINUTE=300
RPC_REQUESTS_PER_MINUTE=20
API_RATE_LIMIT_PER_MINUTE=55

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=DEBUG
LOG_FILE=logs/harvester.log

# ── Misc ──────────────────────────────────────────────────────
TOP_HOLDERS_COUNT=50

# ═══════════════════════════════════════════════════════════════
# PHASE 5.0 — ENHANCED ENTRY FILTERS
# ═══════════════════════════════════════════════════════════════

# ── Entry Selectivity (v5.0) ─────────────────────────────────
# MIN_GINI: floor for holder concentration — too low = range-bound (default: 0.40)
MIN_GINI_COEFFICIENT=0.40
# Token age gate — skip bot-warfare phase and stale tokens
TOKEN_MIN_AGE_MINUTES=30.0
TOKEN_MAX_AGE_HOURS=6.0
# Minimum buy-side transactions in last 5 minutes (default: 15)
MIN_BUY_TXNS_5M=15
# Volume acceleration — 1min rate must exceed 5min avg × this multiplier (default: 3.0)
VOLUME_ACCEL_MULTIPLIER=3.0
# Reject if single tx accounts for > this fraction of 5m volume (whale detection; default: 0.30)
MAX_SINGLE_TXN_CONCENTRATION=0.30

# ── SOL Regime Filter (v5.0) ─────────────────────────────────
# Enable/disable the SOL market regime filter (default: true)
SOL_REGIME_FILTER_ENABLED=true
# SOL/USDC pair address on Raydium for price tracking — SET THIS to the correct pair address.
# Example Raydium SOL/USDC pair: 58oQChx4yWmvKdwLLZzBi4ChoCc2fqCUWaS2GkQ8stGK
# Verify the current address on DexScreener: https://dexscreener.com/solana?q=SOL/USDC
SOL_PAIR_ADDRESS=
# Number of SOL price observations for SMA (default: 15)
SOL_SMA_LOOKBACK=15
# If SOL drops more than this in SOL_CRASH_WINDOW_SECONDS, exit all positions (default: -0.02 = -2%)
SOL_CRASH_PCT=-0.02
# Window (seconds) for SOL crash detection (default: 900 = 15 min)
SOL_CRASH_WINDOW_SECONDS=900.0

# ── UTC Time Blackout (v5.0) ─────────────────────────────────
# No trading between these UTC hours (default: 02:00–06:00 UTC low-liquidity window)
TRADING_BLACKOUT_START_UTC=2
TRADING_BLACKOUT_END_UTC=6

# ── Per-Trade Dynamic Exits (v5.0) ───────────────────────────
# ATR-based take profit: TP = ATR_TP_MULTIPLIER × atr + ATR_TP_COST_BUFFER
ATR_TP_MULTIPLIER=1.5
ATR_TP_COST_BUFFER=0.02
ATR_TP_MIN=0.04
ATR_TP_MAX=0.15
ATR_LOOKBACK_PERIODS=5
# Speed bonus: if price moves SPEED_BONUS_THRESHOLD in first 60s, multiply TP by SPEED_BONUS_MULTIPLIER
SPEED_BONUS_THRESHOLD=0.01
SPEED_BONUS_MULTIPLIER=1.3
SPEED_BONUS_WINDOW_SECONDS=60.0
# Break-even stop: move SL to entry+buffer after BREAKEVEN_ACTIVATION_PCT unrealized gain
BREAKEVEN_ACTIVATION_PCT=0.04
BREAKEVEN_BUFFER_PCT=0.02

# ── Liquidity-Scaled Stop Loss (v5.0) ────────────────────────
# Thin pool (< $100K): tighter SL
SL_THIN_POOL_PCT=-0.06
SL_THIN_POOL_THRESHOLD=100000.0
# Medium pool ($100K–$500K)
SL_MEDIUM_POOL_PCT=-0.08
# Deep pool (> $500K): wider SL allowed
SL_DEEP_POOL_PCT=-0.10
SL_DEEP_POOL_THRESHOLD=500000.0

# ── Trailing Stop Time Decay (v5.0) ──────────────────────────
# After TRAIL_TIGHTEN_1_MINUTES in trade, multiply trail distance by TRAIL_TIGHTEN_1_FACTOR
TRAIL_TIGHTEN_1_MINUTES=15.0
TRAIL_TIGHTEN_1_FACTOR=0.7
TRAIL_TIGHTEN_2_MINUTES=20.0
TRAIL_TIGHTEN_2_FACTOR=0.5
# Hard maximum position duration regardless of trailing state (default: 25 min)
HARD_TIME_STOP_MINUTES=25.0

# ── Portfolio-Level Risk (v5.0) ───────────────────────────────
# If total unrealized PnL across all open positions drops below this, pause new entries
PORTFOLIO_HEAT_LIMIT_PCT=-0.05
PORTFOLIO_HEAT_PAUSE_MINUTES=30.0

# ═══════════════════════════════════════════════════════════════
# PHASE 5.2 — SAFETY ENRICHMENT (RugCheck & pump.fun)
# ═══════════════════════════════════════════════════════════════

# ── RugCheck Integration (v5.2) ────────────────────────────
# Enable RugCheck API safety checks at token discovery (default: true)
RUGCHECK_ENABLED=true
# Reject tokens with RugCheck risk score above this threshold (default: 1000)
RUGCHECK_MAX_SCORE=1000
# Hard-reject tokens where mint authority is NOT renounced (default: true)
RUGCHECK_REQUIRE_MINT_RENOUNCED=true
# Reject tokens where LP is not locked (default: false — many legit tokens have unlocked LP early)
RUGCHECK_REQUIRE_LP_LOCKED=false

# ── Pump.fun Migration Detection (v5.2) ───────────────────
# Enable pump.fun bonding curve migration detection (default: true)
PUMPFUN_CHECK_ENABLED=true
# Allow pump.fun migrations to bypass TOKEN_MIN_AGE_MINUTES gate (default: true)
PUMPFUN_MIGRATION_BONUS=true
